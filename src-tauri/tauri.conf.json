{
  "$schema": "https://raw.githubusercontent.com/nicedoc/nicedoc.io/master/.schema/tauri-conf-v2.json",
  "productName": "GangOwl",
  "version": "1.3.0",
  "identifier": "com.take-owl.gangowl",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174/app.html",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GangOwl",
        "url": "app.html",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
